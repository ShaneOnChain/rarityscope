# NEXT_PUBLIC_SITE_URL — public origin of the deployed site.
# Used for metadataBase (Open Graph / canonical links) and any absolute URLs.
# Optional: defaults to http://localhost:3000 when unset, which is fine for local dev.
# Set it to your deployed origin in production, e.g. https://rarity.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
